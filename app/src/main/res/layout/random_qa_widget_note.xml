<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_card_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_note_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:textColor="@android:color/white"
            android:textSize="18sp" />

        <ImageView
            android:id="@+id/widget_open_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/widget_action_button_bg"
            android:contentDescription="@string/widget_open_note"
            android:padding="7dp"
            android:scaleType="fitCenter"
            android:src="@drawable/widget_obsidian_logo" />

        <ImageView
            android:id="@+id/widget_topic_chatgpt_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/widget_action_button_bg"
            android:contentDescription="@string/widget_open_topic_chat"
            android:padding="7dp"
            android:scaleType="fitCenter"
            android:src="@drawable/widget_chatgpt_logo" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_question_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical" />
</LinearLayout>
